  "components": {
    "schemas": {
      "ContactInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "email": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "phoneNumber": {
            "type": "string",
            "pattern": "^\\+?91[-.\\s]?[6789]\\d{9}$"
          }
        }
      },
      "HotelDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "hotelName": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "contactInfo": {
            "$ref": "#/components/schemas/ContactInfo"
          },
          "photos": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "amenities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "active": {
            "type": "boolean"
          }
        },
        "required": [
          "city",
          "contactInfo",
          "hotelName"
        ]
      },
      "HotelSearchRequestDTO": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string"
          },
