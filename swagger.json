        "type": "object",
        "properties": {
          "hotelId": {
            "type": "integer",
            "format": "int64"
          },
          "roomId": {
            "type": "integer",
            "format": "int64"
          },
          "checkInDate": {
            "type": "string",
            "format": "date"
          },
          "checkOutDate": {
            "type": "string",
            "format": "date"
          },
          "roomsCount": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "RoomDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "roomType": {
            "type": "string"
          },
          "basePrice": {
            "type": "number"
          },
          "photos": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "amenities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "totalCount": {
            "type": "integer",
            "format": "int32"
          },
          "capacity": {
            "type": "integer",
            "format": "int32",
            "minimum": 1
          }
        },
        "required": [
          "roomType"
        ]
      },
      "AssignRoleDTO": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "GUEST",
                "HOTEL_MANAGER"
              ]
            },
            "uniqueItems": true
          }
        }
      },
